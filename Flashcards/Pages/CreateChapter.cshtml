@page
@model Web.Pages.CreateChapterModel
@{
    ViewData["Title"] = "Create Chapter";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Create New Chapter</h3>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="NewChapter.SubjectId" />
                        <!-- Name Field -->
                        <div class="mb-3">
                            <label asp-for="NewChapter.Name" class="form-label fw-semibold">Chapter Name</label>
                            <input asp-for="NewChapter.Name" class="form-control" placeholder="e.g., Multiplication, addition, conjunction" required>
                            <span asp-validation-for="NewChapter.Name" class="text-danger small"></span>
                        </div>

                        <!-- Description Field -->
                        <div class="mb-4">
                            <label asp-for="NewChapter.Description" class="form-label fw-semibold">Description</label>
                            <textarea asp-for="NewChapter.Description" class="form-control" rows="4" placeholder="Add a brief description of this chapter (optional)"></textarea>
                            <span asp-validation-for="NewChapter.Description" class="text-danger small"></span>
                        </div>

                        <!-- Form Actions -->
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary flex-grow-1">
                                <i class="bi bi-plus-circle"></i> Create Chapter
                            </button>
                            <a href="/" class="btn btn-secondary flex-grow-1">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>



<style>
    .card {
        border: none;
        border-radius: 8px;
    }

    .card-header {
        border-radius: 8px 8px 0 0;
        padding: 1.5rem;
    }

    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
    }

    .btn {
        border-radius: 6px;
        font-weight: 500;
        transition: all 0.2s;
    }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
        }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}