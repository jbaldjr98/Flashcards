@page
@model Web.Pages.CreateChapterModel
@{
    ViewData["Title"] = "Create Chapter";
}

<div class="cc-page">
    <div class="cc-header">
        <h1 class="cc-title">Create Chapter</h1>
        <p class="cc-subtitle">Chapters organise your flashcards within a subject.</p>
    </div>

    <form method="post" class="cc-form">
        <input type="hidden" asp-for="NewChapter.SubjectId" />

        <div class="cc-field">
            <label asp-for="NewChapter.Name" class="cc-label">Chapter Name</label>
            <input asp-for="NewChapter.Name" class="cc-input" placeholder="e.g., Multiplication, Conjunctions, The Renaissance" required>
            <span asp-validation-for="NewChapter.Name" class="cc-error"></span>
        </div>

        <div class="cc-field">
            <label asp-for="NewChapter.Description" class="cc-label">Description <span class="cc-optional">optional</span></label>
            <textarea asp-for="NewChapter.Description" class="cc-input cc-textarea" rows="4" placeholder="A brief description of this chapter…"></textarea>
            <span asp-validation-for="NewChapter.Description" class="cc-error"></span>
        </div>

        <div class="cc-actions">
            <a href="/" class="cc-cancel-btn">Cancel</a>
            <button type="submit" class="cc-submit-btn">Create Chapter</button>
        </div>

    </form>
</div>

<style>
    .cc-page {
        max-width: 560px;
        margin: 3rem auto;
        padding: 0 1.5rem 4rem;
    }

    .cc-header { margin-bottom: 2.25rem; }
    .cc-title   { font-size: 1.75rem; font-weight: 700; color: #f3f4f6; margin: 0 0 .35rem; }
    .cc-subtitle { color: #9ca3af; margin: 0; font-size: .95rem; }

    .cc-form { display: flex; flex-direction: column; gap: 1.5rem; }

    .cc-field { display: flex; flex-direction: column; gap: .45rem; }

    .cc-label {
        font-size: .8rem;
        font-weight: 600;
        letter-spacing: .05em;
        text-transform: uppercase;
        color: #9ca3af;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .cc-optional {
        font-size: .7rem;
        font-weight: 500;
        letter-spacing: .03em;
        text-transform: none;
        color: #6b7280;
        background: #1f2937;
        padding: .1rem .45rem;
        border-radius: 4px;
    }

    .cc-input {
        background: #1f2937;
        border: 1.5px solid #374151;
        border-radius: 8px;
        padding: .65rem .85rem;
        font-size: .95rem;
        color: #e5e7eb;
        transition: border-color .15s, box-shadow .15s;
        width: 100%;
        box-sizing: border-box;
    }

    .cc-input::placeholder { color: #4b5563; }

    .cc-input:focus {
        outline: none;
        border-color: #818cf8;
        box-shadow: 0 0 0 3px rgba(129,140,248,.2);
    }

    .cc-textarea { resize: vertical; min-height: 100px; line-height: 1.55; }

    .cc-error { font-size: .8rem; color: #f87171; }

    .cc-actions {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 1rem;
        margin-top: .5rem;
    }

    .cc-cancel-btn {
        font-size: .9rem;
        font-weight: 500;
        color: #6b7280;
        text-decoration: none;
        padding: .55rem 1.25rem;
        border-radius: 8px;
        transition: background .15s, color .15s;
    }

    .cc-cancel-btn:hover { background: #1f2937; color: #d1d5db; }

    .cc-submit-btn {
        padding: .6rem 1.75rem;
        background: #6366f1;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: .95rem;
        font-weight: 600;
        cursor: pointer;
        transition: background .15s, box-shadow .15s;
    }

    .cc-submit-btn:hover { background: #4f46e5; box-shadow: 0 4px 12px rgba(99,102,241,.4); }
</style>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
