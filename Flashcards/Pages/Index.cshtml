@page
@model Flashcards.Pages.IndexModel
@{
    ViewData["Title"] = "Flashcards";
}

<div class="ix-page">

    <div class="ix-header">
        <div>
            <h1 class="ix-title">My Subjects</h1>
            <p class="ix-subtitle">Select a subject to study, update, or delete it.</p>
        </div>
        <a href="/CreateFlashcards" class="ix-create-btn">+ New Deck</a>
    </div>

    @if (!Model.Subjects.Any())
    {
        <div class="ix-empty">
            <p class="ix-empty-text">No subjects yet.</p>
            <a href="/CreateSubject" class="ix-empty-link">Create your first subject →</a>
        </div>
    }
    else
    {
        <div class="ix-table-wrap">
            <table class="ix-table">
                <thead>
                    <tr>
                        <th class="ix-th">Subject</th>
                        <th class="ix-th">Description</th>
                        <th class="ix-th ix-th-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var subject in Model.Subjects)
                    {
                        <tr class="ix-row">
                            <td class="ix-td ix-name">@subject.Name</td>
                            <td class="ix-td ix-desc">@(subject.Description ?? "—")</td>
                            <td class="ix-td ix-actions">
                                <a href="/Study?subjectId=@subject.Id" class="ix-btn ix-btn-study" title="Study">Study</a>
                                <a href="/UpdateDeck?subjectId=@subject.Id" class="ix-btn ix-btn-update" title="Update">Update</a>
                                <button class="ix-btn ix-btn-delete"
                                        data-subject-id="@subject.Id"
                                        data-subject-name="@subject.Name"
                                        onclick="confirmDelete(this)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>

<!-- Delete confirmation modal -->
<div class="ix-modal-backdrop" id="deleteModal" onclick="closeModal(event)">
    <div class="ix-modal">
        <h2 class="ix-modal-title">Delete Subject</h2>
        <p class="ix-modal-body">Are you sure you want to delete <strong id="deleteSubjectName"></strong>? All chapters and flashcards within this subject will also be permanently deleted. This cannot be undone.</p>
        <form method="post" asp-page-handler="DeleteSubject">
            <input type="hidden" name="subjectId" id="deleteSubjectId" />
            @Html.AntiForgeryToken()
            <div class="ix-modal-actions">
                <button type="button" class="ix-modal-cancel" onclick="closeDeleteModal()">Cancel</button>
                <button type="submit" class="ix-modal-confirm">Yes, Delete</button>
            </div>
        </form>
    </div>
</div>

<style>
    .ix-page {
        max-width: 860px;
        margin: 3rem auto;
        padding: 0 1.5rem 4rem;
    }

    /* ── Header ── */
    .ix-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
        gap: 1rem;
    }

    .ix-title    { font-size: 1.75rem; font-weight: 700; color: #f3f4f6; margin: 0 0 .3rem; }
    .ix-subtitle { font-size: .95rem; color: #9ca3af; margin: 0; }

    .ix-create-btn {
        white-space: nowrap;
        padding: .6rem 1.4rem;
        background: #6366f1;
        color: #fff;
        text-decoration: none;
        border-radius: 8px;
        font-size: .9rem;
        font-weight: 600;
        transition: background .15s, box-shadow .15s;
    }

    .ix-create-btn:hover { background: #4f46e5; box-shadow: 0 4px 12px rgba(99,102,241,.4); color: #fff; }

    /* ── Empty state ── */
    .ix-empty {
        text-align: center;
        padding: 4rem 1rem;
        border: 1.5px dashed #374151;
        border-radius: 10px;
    }

    .ix-empty-text { color: #6b7280; font-size: 1rem; margin: 0 0 .75rem; }
    .ix-empty-link { color: #818cf8; text-decoration: none; font-weight: 600; font-size: .95rem; }
    .ix-empty-link:hover { color: #a5b4fc; }

    /* ── Table ── */
    .ix-table-wrap {
        border: 1.5px solid #374151;
        border-radius: 10px;
        overflow: hidden;
    }

    .ix-table { width: 100%; border-collapse: collapse; }

    .ix-th {
        padding: .65rem 1.1rem;
        font-size: .75rem;
        font-weight: 600;
        letter-spacing: .05em;
        text-transform: uppercase;
        color: #6b7280;
        background: #111827;
        border-bottom: 1.5px solid #374151;
        text-align: left;
    }

    .ix-th-right { text-align: right; }

    .ix-row { border-bottom: 1px solid #1f2937; transition: background .12s; }
    .ix-row:last-child { border-bottom: none; }
    .ix-row:hover { background: #1a2234; }

    .ix-td { padding: .85rem 1.1rem; font-size: .95rem; color: #e5e7eb; vertical-align: middle; }

    .ix-name { font-weight: 600; color: #f3f4f6; width: 22%; }
    .ix-desc { color: #9ca3af; font-size: .9rem; }

    .ix-actions {
        text-align: right;
        white-space: nowrap;
        width: 1%;
    }

    /* ── Action buttons ── */
    .ix-btn {
        display: inline-flex;
        align-items: center;
        padding: .3rem .85rem;
        border-radius: 6px;
        font-size: .8rem;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        border: 1.5px solid transparent;
        transition: background .15s, color .15s, border-color .15s;
        margin-left: .4rem;
    }

    .ix-btn-study {
        color: #818cf8;
        border-color: #3730a3;
        background: #1e1b4b;
    }

    .ix-btn-study:hover { background: #312e81; color: #c7d2fe; border-color: #818cf8; }

    .ix-btn-update {
        color: #fbbf24;
        border-color: #78350f;
        background: #1c1108;
    }

    .ix-btn-update:hover { background: #451a03; color: #fde68a; border-color: #f59e0b; }

    .ix-btn-delete {
        color: #f87171;
        border-color: #7f1d1d;
        background: #1c0a0a;
    }

    .ix-btn-delete:hover { background: #450a0a; color: #fca5a5; border-color: #ef4444; }

    /* ── Modal ── */
    .ix-modal-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.6);
        backdrop-filter: blur(3px);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }

    .ix-modal-backdrop.open { display: flex; }

    .ix-modal {
        background: #1f2937;
        border: 1.5px solid #374151;
        border-radius: 12px;
        padding: 2rem;
        max-width: 420px;
        width: 90%;
        box-shadow: 0 20px 60px rgba(0,0,0,.5);
    }

    .ix-modal-title { font-size: 1.2rem; font-weight: 700; color: #f3f4f6; margin: 0 0 .75rem; }
    .ix-modal-body  { color: #9ca3af; font-size: .95rem; margin: 0 0 1.75rem; line-height: 1.55; }
    .ix-modal-body strong { color: #f3f4f6; }

    .ix-modal-actions { display: flex; justify-content: flex-end; gap: .75rem; }

    .ix-modal-cancel {
        padding: .5rem 1.2rem;
        border-radius: 7px;
        border: 1.5px solid #374151;
        background: none;
        color: #9ca3af;
        font-size: .9rem;
        font-weight: 600;
        cursor: pointer;
        transition: background .15s, color .15s;
    }

    .ix-modal-cancel:hover { background: #111827; color: #e5e7eb; }

    .ix-modal-confirm {
        padding: .5rem 1.2rem;
        border-radius: 7px;
        border: none;
        background: #dc2626;
        color: #fff;
        font-size: .9rem;
        font-weight: 600;
        cursor: pointer;
        transition: background .15s, box-shadow .15s;
    }

    .ix-modal-confirm:hover { background: #b91c1c; box-shadow: 0 4px 12px rgba(220,38,38,.4); }
</style>

@section Scripts {
    <script>
        function confirmDelete(btn) {
            document.getElementById('deleteSubjectName').textContent = btn.dataset.subjectName;
            document.getElementById('deleteSubjectId').value = btn.dataset.subjectId;
            document.getElementById('deleteModal').classList.add('open');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.remove('open');
        }

        function closeModal(e) {
            if (e.target === document.getElementById('deleteModal')) closeDeleteModal();
        }
    </script>
}
