@page
@model Web.Pages.CreateSubjectModel
@{
    ViewData["Title"] = "Create Subject";
}

<div class="cs-page">
    <div class="cs-header">
        <h1 class="cs-title">Create Subject</h1>
        <p class="cs-subtitle">Subjects group your chapters and flashcards together.</p>
    </div>

    <form method="post" class="cs-form">

        <div class="cs-field">
            <label asp-for="NewSubject.Name" class="cs-label">Subject Name</label>
            <input asp-for="NewSubject.Name" class="cs-input" placeholder="e.g., Biology, Spanish, History" required>
            <span asp-validation-for="NewSubject.Name" class="cs-error"></span>
        </div>

        <div class="cs-field">
            <label asp-for="NewSubject.Description" class="cs-label">Description <span class="cs-optional">optional</span></label>
            <textarea asp-for="NewSubject.Description" class="cs-input cs-textarea" rows="4" placeholder="A brief description of this subject…"></textarea>
            <span asp-validation-for="NewSubject.Description" class="cs-error"></span>
        </div>

        <div class="cs-actions">
            <a href="/" class="cs-cancel-btn">Cancel</a>
            <button type="submit" class="cs-submit-btn">Create Subject</button>
        </div>

    </form>
</div>

<style>
    .cs-page {
        max-width: 560px;
        margin: 3rem auto;
        padding: 0 1.5rem 4rem;
    }

    .cs-header { margin-bottom: 2.25rem; }
    .cs-title   { font-size: 1.75rem; font-weight: 700; color: #f3f4f6; margin: 0 0 .35rem; }
    .cs-subtitle { color: #9ca3af; margin: 0; font-size: .95rem; }

    .cs-form { display: flex; flex-direction: column; gap: 1.5rem; }

    .cs-field { display: flex; flex-direction: column; gap: .45rem; }

    .cs-label {
        font-size: .8rem;
        font-weight: 600;
        letter-spacing: .05em;
        text-transform: uppercase;
        color: #9ca3af;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .cs-optional {
        font-size: .7rem;
        font-weight: 500;
        letter-spacing: .03em;
        text-transform: none;
        color: #6b7280;
        background: #1f2937;
        padding: .1rem .45rem;
        border-radius: 4px;
    }

    .cs-input {
        background: #1f2937;
        border: 1.5px solid #374151;
        border-radius: 8px;
        padding: .65rem .85rem;
        font-size: .95rem;
        color: #e5e7eb;
        transition: border-color .15s, box-shadow .15s;
        width: 100%;
        box-sizing: border-box;
    }

    .cs-input::placeholder { color: #4b5563; }

    .cs-input:focus {
        outline: none;
        border-color: #818cf8;
        box-shadow: 0 0 0 3px rgba(129,140,248,.2);
    }

    .cs-textarea { resize: vertical; min-height: 100px; line-height: 1.55; }

    .cs-error { font-size: .8rem; color: #f87171; }

    .cs-actions {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 1rem;
        margin-top: .5rem;
    }

    .cs-cancel-btn {
        font-size: .9rem;
        font-weight: 500;
        color: #6b7280;
        text-decoration: none;
        padding: .55rem 1.25rem;
        border-radius: 8px;
        transition: background .15s, color .15s;
    }

    .cs-cancel-btn:hover { background: #1f2937; color: #d1d5db; }

    .cs-submit-btn {
        padding: .6rem 1.75rem;
        background: #6366f1;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: .95rem;
        font-weight: 600;
        cursor: pointer;
        transition: background .15s, box-shadow .15s;
    }

    .cs-submit-btn:hover { background: #4f46e5; box-shadow: 0 4px 12px rgba(99,102,241,.4); }
</style>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
